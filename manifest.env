# Pinned build inputs. Human-readable record of what the workflow targets; keep in sync with
# .github/workflows/build.yml (the workflow currently reads XCODE_VERSION / MPV_TAP_REF from its
# own env — this file documents the full set and the rationale).

IINA_REF=ae76dcf73082c86770ffe0988d7d75d202d723d4   # iina/iina; pinned to last good commit before an unrelated regression
MPV_TAP_REF=master               # iina/homebrew-mpv-iina (formulas: ffmpeg-iina, mpv-iina)
FFMPEG_VERSION=8.0               # what ffmpeg-iina pins; MMT patch base is 8.0.1 (compatible)
MPV_RELEASE=iina-release/1.5.0   # what mpv-iina pins (libmpv)
XCODE_VERSION=26.5               # matches iina/iina ci.yml (runner: macos-26)
